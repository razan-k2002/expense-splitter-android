<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for Dark Mode. -->
    <style name="Base.Theme.PersonalExpenseSplitterProject" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main Brand Colors -->
        <item name="colorPrimary">@color/blue</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <!-- Background & Surface Colors (Adapts to Dark Mode) -->
        <item name="android:windowBackground">#121212</item> <!-- Dark background -->
        <item name="colorSurface">#1E1E1E</item> <!-- Dark grey cards -->
        <item name="colorOnSurface">#FFFFFF</item> <!-- White text -->

        <!-- Status bar and navigation -->
        <item name="android:statusBarColor">#121212</item>
        <item name="colorControlActivated">@color/blue</item>
    </style>
</resources>