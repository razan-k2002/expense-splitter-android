<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.PersonalExpenseSplitterProject" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/blue</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/blue</item>
        <item name="colorOnSecondary">@android:color/white</item>

        <item name="android:windowBackground">#F7F7F7</item> <!-- Soft light grey bg -->
        <item name="colorSurface">@android:color/white</item> <!-- White cards -->
        <item name="colorOnSurface">@android:color/black</item> <!-- Black text -->

        <!-- Status bar and navigation -->
        <item name="android:statusBarColor">?attr/colorPrimary</item>
        <item name="colorControlActivated">@color/blue</item>
    </style>

    <!-- Custom Style for Circle Images -->
    <style name="CircleImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Theme.PersonalExpenseSplitterProject" parent="Base.Theme.PersonalExpenseSplitterProject" />
</resources>